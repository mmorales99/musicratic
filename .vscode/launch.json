{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Musicratic API",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/back/Musicratic.Core/bin/Debug/net10.0/Musicratic.Core.dll",
      "args": [],
      "cwd": "${workspaceFolder}/back/Musicratic.Core",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/scalar/v1"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}"
      }
    },
    {
      "name": "Run Tests",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build tests",
      "program": "${workspaceFolder}/back/Musicratic.Core.Tests/bin/Debug/net10.0/Musicratic.Core.Tests.dll",
      "args": [],
      "cwd": "${workspaceFolder}/back/Musicratic.Core.Tests",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    }
  ]
}
