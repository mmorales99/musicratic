@host = http://localhost:5113
@hubId = hub-1
@ownerId = owner-1
@userId = user-1

# ── User CRUD ─────────────────────────────────────────────────────────

### Create a user
POST {{host}}/users
Content-Type: application/json

{
  "userId": "{{userId}}"
}

###

### List all users
GET {{host}}/users

###

### Get a user by id
GET {{host}}/users/{{userId}}

###

### Delete a user
DELETE {{host}}/users/{{userId}}

###

# ── Hub management ────────────────────────────────────────────────────

### Create a hub
POST {{host}}/hubs
Content-Type: application/json

{
  "hubId": "{{hubId}}",
  "ownerId": "{{ownerId}}",
  "isPublic": true
}

###

### Get hub status
GET {{host}}/hubs/{{hubId}}

###

# ── Track list ────────────────────────────────────────────────────────

### Set track list (3 tracks of different durations)
PUT {{host}}/hubs/{{hubId}}/tracks
Content-Type: application/json

{
  "tracks": [
    { "id": "track-1", "duration": "00:03:30" },
    { "id": "track-2", "duration": "00:04:15" },
    { "id": "track-3", "duration": "00:00:40" }
  ]
}

###

# ── Playback controls ─────────────────────────────────────────────────

### Play
POST {{host}}/hubs/{{hubId}}/play

###

### Stop
POST {{host}}/hubs/{{hubId}}/stop

###

### Skip to next track
POST {{host}}/hubs/{{hubId}}/next

###

### Shuffle queue
POST {{host}}/hubs/{{hubId}}/shuffle

###

# ── Users ─────────────────────────────────────────────────────────────

### Attach a user
POST {{host}}/hubs/{{hubId}}/users
Content-Type: application/json

{
  "userId": "{{userId}}"
}

###

### Detach a user
DELETE {{host}}/hubs/{{hubId}}/users/{{userId}}

###

# ── Ban list ──────────────────────────────────────────────────────────

### Ban a track
POST {{host}}/hubs/{{hubId}}/banned-tracks
Content-Type: application/json

{
  "trackId": "track-3"
}

###

### Unban a track
DELETE {{host}}/hubs/{{hubId}}/banned-tracks/track-3

###

# ── Suggestions & voting ──────────────────────────────────────────────

### Suggest a track (must be ≤ 6 min and not banned; queue needs an eligible track ≥ 45 s)
POST {{host}}/hubs/{{hubId}}/suggestions
Content-Type: application/json

{
  "trackId": "track-suggested",
  "duration": "00:03:00"
}

###

### Cast a vote (userId must be attached to the hub)
POST {{host}}/hubs/{{hubId}}/vote
Content-Type: application/json

{
  "userId": "{{userId}}",
  "isUpVote": true
}

###

### Cast a downvote
POST {{host}}/hubs/{{hubId}}/vote
Content-Type: application/json

{
  "userId": "{{userId}}",
  "isUpVote": false
}

###

# ── Config ────────────────────────────────────────────────────────────

### Update fade-out duration (5–15 s, clamped automatically)
PATCH {{host}}/hubs/{{hubId}}/config
Content-Type: application/json

{
  "fadeOutDurationSeconds": 8
}

###

