@page "/hub"
@rendermode InteractiveServer
@using Musicratic.Front.MVP.Services
@inject MusicraticClient Api

<PageTitle>Hub Tester — Musicratic</PageTitle>

<h2>Hub Tester</h2>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @_messageClass alert-dismissible" role="alert">
        <pre class="mb-0" style="white-space:pre-wrap;font-size:.85rem">@_message</pre>
        <button type="button" class="btn-close" @onclick="() => _message = null"></button>
    </div>
}

<!-- ── Load / Create hub ─────────────────────────────────────────── -->
<div class="card mb-3">
    <div class="card-header fw-semibold">Load / Create hub</div>
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-sm-3">
                <label class="form-label mb-1">Hub ID</label>
                <input class="form-control" @bind="_hubId" placeholder="my-hub" />
            </div>
            <div class="col-sm-3">
                <label class="form-label mb-1">Owner ID (create only)</label>
                <input class="form-control" @bind="_ownerId" placeholder="alice" />
            </div>
            <div class="col-sm-2 d-flex align-items-center pt-3">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" @bind="_isPublic" id="chkPublic" />
                    <label class="form-check-label" for="chkPublic">Public</label>
                </div>
            </div>
            <div class="col-sm-auto">
                <button class="btn btn-outline-primary me-1" @onclick="LoadHub" disabled="@_busy">Load</button>
                <button class="btn btn-primary" @onclick="CreateHub" disabled="@_busy">Create</button>
            </div>
        </div>
    </div>
</div>

@if (_hub != null)
{
    <!-- ── Hub status strip ─────────────────────────────────────────── -->
    <div class="card mb-3 border-@StateColor(_hub.PlaybackState)">
        <div class="card-header d-flex justify-content-between align-items-center fw-semibold">
            <span>@_hub.Id <span class="badge bg-@StateColor(_hub.PlaybackState) ms-1">@_hub.PlaybackState</span>
                @if (_hub.IsPublic) { <span class="badge bg-secondary ms-1">public</span> }
            </span>
            <button class="btn btn-sm btn-outline-secondary" @onclick="Refresh" disabled="@_busy">↺ Refresh</button>
        </div>
        <div class="card-body pb-1">
            <div class="row g-3">
                <div class="col-auto">
                    <small class="text-muted d-block">Owner</small>
                    <strong>@_hub.OwnerId</strong>
                </div>
                <div class="col-auto">
                    <small class="text-muted d-block">Now playing</small>
                    <strong>@(_hub.PlayingTrackId ?? "—")</strong>
                    @if (_hub.PlayingTrackId != null)
                    { <span class="ms-1 text-muted">(@_hub.PlayingTrackPositionSeconds.ToString("F0") s)</span> }
                    @if (_hub.IsSuggestedTrackPlaying) { <span class="badge bg-info ms-1">suggested</span> }
                </div>
                <div class="col-auto">
                    <small class="text-muted d-block">Queue (@_hub.QueueTrackIds.Count)</small>
                    <small>@string.Join(", ", _hub.QueueTrackIds.Take(5))@(_hub.QueueTrackIds.Count > 5 ? "…" : "")</small>
                </div>
                <div class="col-auto">
                    <small class="text-muted d-block">Users (@_hub.AttachedUserIds.Count)</small>
                    <small>@string.Join(", ", _hub.AttachedUserIds)</small>
                </div>
                <div class="col-auto">
                    <small class="text-muted d-block">Fade-out</small>
                    <small>@_hub.FadeOutDurationSeconds s</small>
                </div>
            </div>

            @if (_hub.CurrentVoting != null)
            {
                <hr class="my-2" />
                <div class="d-flex align-items-center gap-3 flex-wrap">
                    <span class="badge bg-warning text-dark">VOTE IN PROGRESS</span>
                    <span><strong>Track:</strong> @_hub.CurrentVoting.TrackId</span>
                    <span><strong>Phase:</strong> @_hub.CurrentVoting.Phase</span>
                    <span><strong>Up:</strong> @_hub.CurrentVoting.UpVotes</span>
                    <span><strong>Down:</strong> @_hub.CurrentVoting.DownVotes</span>
                    <span><strong>Time left:</strong> @_hub.CurrentVoting.TimeLeftSeconds.ToString("F0") s</span>
                    @if (!_hub.CurrentVoting.IsActive) { <span class="badge bg-secondary">expired</span> }
                </div>
            }
        </div>
    </div>

    <div class="row g-3">

        <!-- ── Playback ─────────────────────────────────────────────── -->
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header fw-semibold">Playback</div>
                <div class="card-body d-flex gap-2 flex-wrap align-items-start">
                    <button class="btn btn-success" @onclick="() => DoHubAction(Api.PlayAsync)" disabled="@_busy">▶ Play</button>
                    <button class="btn btn-danger" @onclick="() => DoHubAction(Api.StopAsync)" disabled="@_busy">■ Stop</button>
                    <button class="btn btn-secondary" @onclick="() => DoHubAction(Api.NextAsync)" disabled="@_busy">⏭ Next</button>
                    <button class="btn btn-secondary" @onclick="() => DoHubAction(Api.ShuffleAsync)" disabled="@_busy">⇄ Shuffle</button>
                </div>
            </div>
        </div>

        <!-- ── Config ───────────────────────────────────────────────── -->
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header fw-semibold">Config</div>
                <div class="card-body">
                    <label class="form-label">Fade-out duration (5–15 s)</label>
                    <div class="input-group">
                        <input type="number" class="form-control" @bind="_fadeOutSeconds" min="5" max="15" step="1" />
                        <button class="btn btn-outline-primary" @onclick="UpdateConfig" disabled="@_busy">Apply</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Vote ─────────────────────────────────────────────────── -->
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header fw-semibold">Cast vote</div>
                <div class="card-body">
                    <div class="mb-2">
                        <label class="form-label mb-1">Voter user ID</label>
                        <input class="form-control" @bind="_voteUserId" placeholder="alice" />
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-success flex-fill" @onclick="() => CastVote(true)" disabled="@_busy">👍 Up</button>
                        <button class="btn btn-outline-danger flex-fill" @onclick="() => CastVote(false)" disabled="@_busy">👎 Down</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Track list ────────────────────────────────────────────── -->
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header fw-semibold">Set track list</div>
                <div class="card-body">
                    <p class="text-muted small">Enter one track per line: <code>track-id duration</code> (e.g. <code>track-1 00:03:30</code>)</p>
                    <textarea class="form-control font-monospace mb-2" rows="5" @bind="_tracksText"
                              placeholder="track-1 00:03:30&#10;track-2 00:02:45&#10;track-3 00:04:00"></textarea>
                    <button class="btn btn-primary" @onclick="SetTracks" disabled="@_busy">Set tracks</button>
                </div>
            </div>
        </div>

        <!-- ── Suggest a track ──────────────────────────────────────── -->
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header fw-semibold">Suggest a track</div>
                <div class="card-body">
                    <div class="mb-2">
                        <label class="form-label mb-1">Track ID</label>
                        <input class="form-control" @bind="_suggestTrackId" placeholder="track-7" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label mb-1">Duration</label>
                        <input class="form-control" @bind="_suggestDuration" placeholder="00:03:30" />
                    </div>
                    <button class="btn btn-primary" @onclick="SuggestTrack" disabled="@_busy">Suggest</button>
                </div>
            </div>
        </div>

        <!-- ── Attached users ────────────────────────────────────────── -->
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header fw-semibold">Attached users</div>
                <div class="card-body">
                    <div class="input-group mb-2">
                        <input class="form-control" @bind="_attachUserId" placeholder="User ID to attach" />
                        <button class="btn btn-outline-primary" @onclick="AttachUser" disabled="@_busy">Attach</button>
                    </div>
                    @if (_hub.AttachedUserIds.Count == 0)
                    {
                        <p class="text-muted small">No users attached.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                        @foreach (var uid in _hub.AttachedUserIds)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <span>@uid @if (uid == _hub.OwnerId) { <span class="badge bg-primary ms-1">owner</span> }</span>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DetachUser(uid)" disabled="@_busy">Detach</button>
                            </li>
                        }
                        </ul>
                    }
                </div>
            </div>
        </div>

        <!-- ── Ban list ───────────────────────────────────────────────── -->
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header fw-semibold">Ban list</div>
                <div class="card-body">
                    <div class="input-group mb-2">
                        <input class="form-control" @bind="_banTrackId" placeholder="Track ID to ban" />
                        <button class="btn btn-outline-danger" @onclick="BanTrack" disabled="@_busy">Ban</button>
                    </div>
                    @if (_hub.BannedTrackIds.Count == 0)
                    {
                        <p class="text-muted small">No tracks banned.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                        @foreach (var tid in _hub.BannedTrackIds)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <span class="font-monospace">@tid</span>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => UnbanTrack(tid)" disabled="@_busy">Unban</button>
                            </li>
                        }
                        </ul>
                    }
                </div>
            </div>
        </div>

    </div>
}

@code {
    // Hub selector
    private string _hubId = "";
    private string _ownerId = "";
    private bool _isPublic;

    // Live state
    private HubStatusDto? _hub;
    private bool _busy;
    private string? _message;
    private string _messageClass = "alert-success";

    // Section fields
    private double _fadeOutSeconds = 10;
    private string _tracksText = "";
    private string _suggestTrackId = "";
    private string _suggestDuration = "00:03:30";
    private string _voteUserId = "";
    private string _attachUserId = "";
    private string _banTrackId = "";

    private async Task LoadHub()
    {
        if (string.IsNullOrWhiteSpace(_hubId)) return;
        _busy = true;
        try
        {
            _hub = await Api.GetHubAsync(_hubId.Trim());
            if (_hub is null) ShowError($"Hub '{_hubId}' not found.");
            else
            {
                _fadeOutSeconds = _hub.FadeOutDurationSeconds;
                ShowSuccess($"Hub '{_hub.Id}' loaded.");
            }
        }
        catch (Exception ex) { ShowError(ex.Message); }
        finally { _busy = false; }
    }

    private async Task CreateHub()
    {
        if (string.IsNullOrWhiteSpace(_hubId) || string.IsNullOrWhiteSpace(_ownerId)) return;
        _busy = true;
        try
        {
            var res = await Api.CreateHubAsync(_hubId.Trim(), _ownerId.Trim(), _isPublic);
            await HandleResponse(res);
        }
        catch (Exception ex) { ShowError(ex.Message); }
        finally { _busy = false; }
    }

    private async Task Refresh()
    {
        if (_hub is null) return;
        _busy = true;
        try { _hub = await Api.GetHubAsync(_hub.Id); }
        catch (Exception ex) { ShowError(ex.Message); }
        finally { _busy = false; }
    }

    private async Task DoHubAction(Func<string, Task<HttpResponseMessage>> action)
    {
        if (_hub is null) return;
        _busy = true;
        try { await HandleResponse(await action(_hub.Id)); }
        catch (Exception ex) { ShowError(ex.Message); }
        finally { _busy = false; }
    }

    private async Task UpdateConfig()
    {
        if (_hub is null) return;
        _busy = true;
        try { await HandleResponse(await Api.UpdateConfigAsync(_hub.Id, _fadeOutSeconds)); }
        catch (Exception ex) { ShowError(ex.Message); }
        finally { _busy = false; }
    }

    private async Task SetTracks()
    {
        if (_hub is null || string.IsNullOrWhiteSpace(_tracksText)) return;
        var tracks = new List<TrackInput>();
        foreach (var line in _tracksText.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            var parts = line.Split(' ', 2);
            if (parts.Length == 2 && TimeSpan.TryParse(parts[1], out var dur))
                tracks.Add(new TrackInput(parts[0], dur));
            else
            {
                ShowError($"Could not parse line: '{line}'. Expected format: track-id HH:mm:ss");
                return;
            }
        }
        _busy = true;
        try { await HandleResponse(await Api.SetTracksAsync(_hub.Id, tracks)); }
        catch (Exception ex) { ShowError(ex.Message); }
        finally { _busy = false; }
    }

    private async Task SuggestTrack()
    {
        if (_hub is null || string.IsNullOrWhiteSpace(_suggestTrackId)) return;
        if (!TimeSpan.TryParse(_suggestDuration, out var dur))
        {
            ShowError("Invalid duration. Use HH:mm:ss format.");
            return;
        }
        _busy = true;
        try { await HandleResponse(await Api.SuggestTrackAsync(_hub.Id, _suggestTrackId.Trim(), dur)); }
        catch (Exception ex) { ShowError(ex.Message); }
        finally { _busy = false; }
    }

    private async Task CastVote(bool isUpVote)
    {
        if (_hub is null || string.IsNullOrWhiteSpace(_voteUserId)) return;
        _busy = true;
        try { await HandleResponse(await Api.VoteAsync(_hub.Id, _voteUserId.Trim(), isUpVote)); }
        catch (Exception ex) { ShowError(ex.Message); }
        finally { _busy = false; }
    }

    private async Task AttachUser()
    {
        if (_hub is null || string.IsNullOrWhiteSpace(_attachUserId)) return;
        _busy = true;
        try
        {
            await HandleResponse(await Api.AttachUserAsync(_hub.Id, _attachUserId.Trim()));
            _attachUserId = "";
        }
        catch (Exception ex) { ShowError(ex.Message); }
        finally { _busy = false; }
    }

    private async Task DetachUser(string userId)
    {
        if (_hub is null) return;
        _busy = true;
        try { await HandleResponse(await Api.DetachUserAsync(_hub.Id, userId)); }
        catch (Exception ex) { ShowError(ex.Message); }
        finally { _busy = false; }
    }

    private async Task BanTrack()
    {
        if (_hub is null || string.IsNullOrWhiteSpace(_banTrackId)) return;
        _busy = true;
        try
        {
            await HandleResponse(await Api.BanTrackAsync(_hub.Id, _banTrackId.Trim()));
            _banTrackId = "";
        }
        catch (Exception ex) { ShowError(ex.Message); }
        finally { _busy = false; }
    }

    private async Task UnbanTrack(string trackId)
    {
        if (_hub is null) return;
        _busy = true;
        try { await HandleResponse(await Api.UnbanTrackAsync(_hub.Id, trackId)); }
        catch (Exception ex) { ShowError(ex.Message); }
        finally { _busy = false; }
    }

    private async Task HandleResponse(HttpResponseMessage res)
    {
        var body = await res.Content.ReadAsStringAsync();
        if (res.IsSuccessStatusCode)
        {
            try { _hub = System.Text.Json.JsonSerializer.Deserialize<HubStatusDto>(body, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }); }
            catch { /* status-only response */ }
            if (_hub != null) _fadeOutSeconds = _hub.FadeOutDurationSeconds;
            ShowSuccess("OK");
        }
        else
        {
            ShowError($"HTTP {(int)res.StatusCode} — {body}");
        }
    }

    private void ShowSuccess(string msg) { _message = msg; _messageClass = "alert-success"; }
    private void ShowError(string msg)   { _message = msg; _messageClass = "alert-danger"; }

    private static string StateColor(string state) => state switch
    {
        "Playing"    => "success",
        "FadingOut"  => "warning",
        _            => "secondary"
    };
}
