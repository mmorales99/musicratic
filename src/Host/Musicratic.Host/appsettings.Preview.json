{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [{ "Name": "Console" }],
    "Enrich": ["FromLogContext"]
  },
  "AllowedHosts": "*",

  "Preview": {
    "Enabled": true,
    "JwtSigningKey": "REPLACE_WITH_64_CHAR_SECRET_IN_AZURE_ENV_VARS"
  },

  "Authentik": {
    "Authority": "",
    "ClientId": "",
    "ClientSecret": ""
  }
}
